# /api/* is handled by functions/api/[[route]].js (Cloudflare Pages Function).
# That file proxies all API calls to https://trynex-api.onrender.com — no
# redirect rule is needed here and _redirects cannot proxy to absolute URLs anyway.

# sitemap.xml and robots.txt are static files served directly from /public.
# Do NOT add proxy rules for these paths.

# SPA fallback — every non-file path is served by index.html so client-side
# routing works on hard refresh. Cloudflare Pages also does this natively for
# sites without a _redirects file, but this rule makes it explicit.
/*        /index.html        200
